<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="522.0" prefWidth="842.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.FuncionarioController">

    <children>

        <!-- Título -->
        <Label layoutX="341.0" layoutY="35.0" text="Funcionário">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <!-- Campos do funcionário -->
        <Label layoutX="79.0" layoutY="121.0" text="Nome funcionário:" />
        <TextField fx:id="txtNome" layoutX="79.0" layoutY="137.0" prefHeight="25.0" prefWidth="150.0" promptText="Nome" />

        <Label layoutX="79.0" layoutY="192.0" text="Função cargo:" />
        <TextField fx:id="txtFuncao" layoutX="79.0" layoutY="207.0" prefHeight="25.0" prefWidth="150.0" promptText="Cargo" />

        <Label layoutX="79.0" layoutY="261.0" text="CPF:" />
        <TextField fx:id="txtCPF" layoutX="79.0" layoutY="275.0" prefHeight="25.0" prefWidth="150.0" promptText="CPF" />

        <!-- Tabela de funcionários -->
        <TableView fx:id="tabelaFuncionarios" layoutX="257.0" layoutY="106.0" prefHeight="201.0" prefWidth="520.0">

            <columns>
                <TableColumn fx:id="colSelecionado" prefWidth="62.0" text="Checkbox" />

                <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />

                <TableColumn fx:id="colNome" prefWidth="108.0" text="Nome" />

                <TableColumn fx:id="colFuncao" prefWidth="128.0" text="Funcao" />

                <TableColumn fx:id="colCPF" prefWidth="182.0" text="CPF" />
            </columns>
        </TableView>

        <!-- Botões CRUD -->
        <Button fx:id="BtCadastrar_func" layoutX="194.0" layoutY="379.0" mnemonicParsing="false" onAction="#cadastrarFuncionario" prefHeight="27.0" prefWidth="85.0" text="Cadastrar" />

        <Button layoutX="322.0" layoutY="379.0" mnemonicParsing="false" onAction="#buscarFuncionario" prefHeight="27.0" prefWidth="85.0" text="Buscar" />

        <Button layoutX="445.0" layoutY="379.0" mnemonicParsing="false" onAction="#atualizarFuncionario" prefHeight="27.0" prefWidth="85.0" text="Atualizar" />

        <Button layoutX="575.0" layoutY="379.0" mnemonicParsing="false" onAction="#excluirFuncionario" prefHeight="27.0" prefWidth="85.0" text="Deletar" />

        <!-- Botão voltar -->
        <Button layoutX="395.0" layoutY="464.0" mnemonicParsing="false" onAction="#BtVoltar" text="Voltar" />

    </children>
</AnchorPane>

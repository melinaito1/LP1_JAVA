<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="522.0" prefWidth="842.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.RemedioController">

   <children>

      <Label layoutX="363.0" layoutY="37.0" text="Remédio">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>

      <!-- Campos do remedio -->
      <Label layoutX="79.0" layoutY="121.0" text="Nome Remédio:" />
      <TextField fx:id="txtNomeRemedio" layoutX="78.0" layoutY="139.0" prefHeight="25.0" prefWidth="150.0" promptText="Remédio" />

      <Label layoutX="79.0" layoutY="192.0" text="Tipo remédio:" />
      <TextField fx:id="txtTipoRemedio" layoutX="79.0" layoutY="210.0" prefHeight="25.0" prefWidth="150.0" promptText="Tipo" />

      <Label layoutX="79.0" layoutY="261.0" text="Preço:" />
      <TextField fx:id="txtPreco" layoutX="79.0" layoutY="278.0" prefHeight="25.0" prefWidth="150.0" promptText="Preço" />

      <!-- Tabela de remedios -->
      <TableView fx:id="tabelaRemedio" layoutX="257.0" layoutY="106.0" prefHeight="201.0" prefWidth="520.0">

         <columns>
            <TableColumn fx:id="colSelecionado" prefWidth="67.0" text="Checkbox" />

            <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />

            <TableColumn fx:id="colNomeRemedio" prefWidth="158.0" text="Remédio" />

            <TableColumn fx:id="colTipo" prefWidth="154.0" text="Tipo" />

            <TableColumn fx:id="colPreco" prefWidth="100.0" text="Preço" />
         </columns>
      </TableView>

      <!-- Botões CRUD -->
      <Button fx:id="BtCadastrar_Remedio" layoutX="194.0" layoutY="379.0" mnemonicParsing="false" onAction="#cadastrarRemedio" prefHeight="27.0" prefWidth="85.0" text="Cadastrar" />

      <Button fx:id="BtBuscar_Remedio" layoutX="322.0" layoutY="379.0" mnemonicParsing="false" onAction="#buscarRemedio" prefHeight="27.0" prefWidth="85.0" text="Buscar" />

      <Button fx:id="BtAtualizar_Remedio" layoutX="445.0" layoutY="379.0" mnemonicParsing="false" onAction="#atualizarRemedio" prefHeight="27.0" prefWidth="85.0" text="Atualizar" />

      <Button fx:id="BtExcluir_Remedio" layoutX="575.0" layoutY="379.0" mnemonicParsing="false" onAction="#excluirRemedio" prefHeight="27.0" prefWidth="85.0" text="Deletar" />

      <!-- Botão voltar -->
      <Button fx:id="Voltar" layoutX="395.0" layoutY="464.0" mnemonicParsing="false" onAction="#BtVoltar" text="Voltar" />

   </children>
</AnchorPane>

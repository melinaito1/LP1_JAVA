<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="522.0" prefWidth="842.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.CabeloController">

   <children>

      <Label layoutX="370.0" layoutY="37.0" text="Cabelo">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>

      <Label layoutX="79.0" layoutY="121.0" text="Tipo:" />
      <TextField fx:id="txtTipo"
                 layoutX="79.0"
                 layoutY="139.0"
                 prefHeight="25.0"
                 prefWidth="150.0"
                 promptText="Tipo" />

      <Label layoutX="79.0" layoutY="192.0" text="Cor:" />
      <TextField fx:id="txtCor"
                 layoutX="79.0"
                 layoutY="210.0"
                 prefHeight="25.0"
                 prefWidth="150.0"
                 promptText="Cor" />

      <Label layoutX="79.0" layoutY="261.0" text="Comprimento:" />
      <TextField fx:id="txtComprimento"
                 layoutX="79.0"
                 layoutY="278.0"
                 prefHeight="25.0"
                 prefWidth="150.0"
                 promptText="Comprimento" />

      <TableView fx:id="tabelaCabelo"
                 layoutX="257.0"
                 layoutY="106.0"
                 prefHeight="201.0"
                 prefWidth="520.0">

         <columns>
            <TableColumn fx:id="colSelecionado"
                         prefWidth="67.0"
                         text="Checkbox" />

            <TableColumn fx:id="colId"
                         prefWidth="40.0"
                         text="ID" />

            <TableColumn fx:id="colTipo"
                         prefWidth="158.0"
                         text="Tipo" />

            <TableColumn fx:id="colCor"
                         prefWidth="154.0"
                         text="Cor" />

            <TableColumn fx:id="colComprimento"
                         prefWidth="100.0"
                         text="Comprimento" />
         </columns>
      </TableView>

      <Button fx:id="BtCadastrar_Cabelo"
              layoutX="194.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#cadastrarCabelo"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Cadastrar" />

      <Button fx:id="BtBuscar_Cabelo"
              layoutX="322.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#buscarCabelo"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Buscar" />

      <Button fx:id="BtAtualizar_Cabelo"
              layoutX="445.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#atualizarCabelo"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Atualizar" />

      <Button fx:id="BtExcluir_Cabelo"
              layoutX="575.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#excluirCabelo"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Deletar" />

      <Button fx:id="BtVoltar"
              layoutX="395.0"
              layoutY="464.0"
              mnemonicParsing="false"
              onAction="#BtVoltar"
              text="Voltar" />

   </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="522.0" prefWidth="842.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.CabeleireiroController">

   <children>

      <Label layoutX="330.0" layoutY="37.0" text="Cabeleireiro">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>

      <Label layoutX="79.0" layoutY="121.0" text="Nome:" />
      <TextField fx:id="txtNome"
                 layoutX="79.0"
                 layoutY="139.0"
                 prefHeight="25.0"
                 prefWidth="150.0"
                 promptText="Nome" />

      <Label layoutX="79.0" layoutY="192.0" text="Turno:" />
      <TextField fx:id="txtTurno"
                 layoutX="79.0"
                 layoutY="210.0"
                 prefHeight="25.0"
                 prefWidth="150.0"
                 promptText="Turno" />

      <Label layoutX="79.0" layoutY="261.0" text="Especialidade:" />
      <TextField fx:id="txtEspecialidade"
                 layoutX="79.0"
                 layoutY="278.0"
                 prefHeight="25.0"
                 prefWidth="150.0"
                 promptText="Especialidade" />

      <TableView fx:id="tabelaCabeleireiro"
                 layoutX="257.0"
                 layoutY="106.0"
                 prefHeight="201.0"
                 prefWidth="520.0">

         <columns>
            <TableColumn fx:id="colSelecionado"
                         prefWidth="67.0"
                         text="Checkbox" />

            <TableColumn fx:id="colId"
                         prefWidth="40.0"
                         text="ID" />

            <TableColumn fx:id="colNome"
                         prefWidth="158.0"
                         text="Nome" />

            <TableColumn fx:id="colTurno"
                         prefWidth="120.0"
                         text="Turno" />

            <TableColumn fx:id="colEspecialidade"
                         prefWidth="135.0"
                         text="Especialidade" />
         </columns>
      </TableView>

      <Button fx:id="BtCadastrar_Cabeleireiro"
              layoutX="194.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#cadastrarCabeleireiro"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Cadastrar" />

      <Button fx:id="BtBuscar_Cabeleireiro"
              layoutX="322.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#buscarCabeleireiro"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Buscar" />

      <Button fx:id="BtAtualizar_Cabeleireiro"
              layoutX="445.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#atualizarCabeleireiro"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Atualizar" />

      <Button fx:id="BtExcluir_Cabeleireiro"
              layoutX="575.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#excluirCabeleireiro"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Deletar" />

      <Button fx:id="BtVoltar"
              layoutX="395.0"
              layoutY="464.0"
              mnemonicParsing="false"
              onAction="#BtVoltar"
              text="Voltar" />

   </children>
</AnchorPane>
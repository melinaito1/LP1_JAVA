<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="522.0" prefWidth="842.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.BarracaController">

   <children>

      <Label layoutX="360.0" layoutY="37.0" text="Barraca">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>

      <Label layoutX="79.0" layoutY="121.0" text="Tamanho:" />
      <TextField fx:id="txtTamanho"
                 layoutX="79.0"
                 layoutY="139.0"
                 prefHeight="25.0"
                 prefWidth="150.0"
                 promptText="grande, medio ou pequeno" />

      <Label layoutX="79.0" layoutY="192.0" text="Cor:" />
      <TextField fx:id="txtCor"
                 layoutX="79.0"
                 layoutY="210.0"
                 prefHeight="25.0"
                 prefWidth="150.0"
                 promptText="Cor" />

      <Label layoutX="79.0" layoutY="261.0" text="Altura:" />
      <TextField fx:id="txtAltura"
                 layoutX="79.0"
                 layoutY="278.0"
                 prefHeight="25.0"
                 prefWidth="150.0"
                 promptText="Altura" />

      <TableView fx:id="tabelaBarraca"
                 layoutX="257.0"
                 layoutY="106.0"
                 prefHeight="201.0"
                 prefWidth="520.0">

         <columns>
            <TableColumn fx:id="colSelecionado"
                         prefWidth="67.0"
                         text="Checkbox" />

            <TableColumn fx:id="colId"
                         prefWidth="40.0"
                         text="ID" />

            <TableColumn fx:id="colTamanho"
                         prefWidth="158.0"
                         text="Tamanho" />

            <TableColumn fx:id="colCor"
                         prefWidth="154.0"
                         text="Cor" />

            <TableColumn fx:id="colAltura"
                         prefWidth="100.0"
                         text="Altura" />
         </columns>
      </TableView>

      <Button fx:id="BtCadastrar_Barraca"
              layoutX="194.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#cadastrarBarraca"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Cadastrar" />

      <Button fx:id="BtBuscar_Barraca"
              layoutX="322.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#buscarBarraca"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Buscar" />

      <Button fx:id="BtAtualizar_Barraca"
              layoutX="445.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#atualizarBarraca"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Atualizar" />

      <Button fx:id="BtExcluir_Barraca"
              layoutX="575.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#excluirBarraca"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Deletar" />

      <Button fx:id="BtVoltar"
              layoutX="395.0"
              layoutY="464.0"
              mnemonicParsing="false"
              onAction="#BtVoltar"
              text="Voltar" />

   </children>
</AnchorPane>
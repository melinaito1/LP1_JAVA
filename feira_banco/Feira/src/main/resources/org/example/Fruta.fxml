<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="522.0" prefWidth="842.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.FrutaController">

   <children>

      <Label layoutX="370.0" layoutY="37.0" text="Fruta">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>

      <Label layoutX="79.0" layoutY="121.0" text="Nome Fruta:" />
      <TextField fx:id="txtNome"
                 layoutX="79.0"
                 layoutY="139.0"
                 prefHeight="25.0"
                 prefWidth="150.0"
                 promptText="Nome" />

      <Label layoutX="79.0" layoutY="192.0" text="Quantidade:" />
      <TextField fx:id="txtQuantidade"
                 layoutX="79.0"
                 layoutY="210.0"
                 prefHeight="25.0"
                 prefWidth="150.0"
                 promptText="Quantidade" />

      <Label layoutX="79.0" layoutY="261.0" text="Preço:" />
      <TextField fx:id="txtPreco"
                 layoutX="79.0"
                 layoutY="278.0"
                 prefHeight="25.0"
                 prefWidth="150.0"
                 promptText="Preço" />

      <TableView fx:id="tabelaFruta"
                 layoutX="257.0"
                 layoutY="106.0"
                 prefHeight="201.0"
                 prefWidth="520.0">

         <columns>
            <TableColumn fx:id="colSelecionado"
                         prefWidth="67.0"
                         text="Checkbox" />

            <TableColumn fx:id="colId"
                         prefWidth="40.0"
                         text="ID" />

            <TableColumn fx:id="colNome"
                         prefWidth="158.0"
                         text="Nome" />

            <TableColumn fx:id="colQuantidade"
                         prefWidth="154.0"
                         text="Quantidade" />

            <TableColumn fx:id="colPreco"
                         prefWidth="100.0"
                         text="Preço" />
         </columns>
      </TableView>

      <Button fx:id="BtCadastrar_Fruta"
              layoutX="194.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#cadastrarFruta"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Cadastrar" />

      <Button fx:id="BtBuscar_Fruta"
              layoutX="322.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#buscarFruta"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Buscar" />

      <Button fx:id="BtAtualizar_Fruta"
              layoutX="445.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#atualizarFruta"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Atualizar" />

      <Button fx:id="BtExcluir_Fruta"
              layoutX="575.0"
              layoutY="379.0"
              mnemonicParsing="false"
              onAction="#excluirFruta"
              prefHeight="27.0"
              prefWidth="85.0"
              text="Deletar" />

      <Button fx:id="BtVoltar"
              layoutX="395.0"
              layoutY="464.0"
              mnemonicParsing="false"
              onAction="#BtVoltar"
              text="Voltar" />

   </children>
</AnchorPane>